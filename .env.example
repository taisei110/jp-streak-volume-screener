# このファイルを .env としてコピーするか、OSの環境変数に設定して使う。
# いずれも「任意」。未設定でもアプリ・スクリーナーは動作する(Discord通知だけがスキップされる)。

# Discordへ結果を自動通知する場合のWebhook URL。
# 取得: Discord > チャンネルの編集 > 連携サービス > ウェブフックを作成 > URLをコピー
# Windows:  setx DISCORD_WEBHOOK_URL "https://discord.com/api/webhooks/xxxx/yyyy"
# macOS/Linux:  export DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/xxxx/yyyy"
DISCORD_WEBHOOK_URL=

# 同一データ基準日でも強制的に再通知したいときだけ 1 にする(既定は多重送信防止で1日1回)。
DISCORD_FORCE_NOTIFY=0
